		"sugar-high": "^1.1.0",
		"tinykeys": "^3.0.0"
	},
	"devDependencies": {
		"@ozzyczech/tsconfig": "^2.0.0",
		"@types/css-modules": "^1.0.5",
		"autoprefixer": "^10.5.0",
		"cssnano": "^7.1.5",
		"oxfmt": "^0.45.0",
		"oxlint": "^1.60.0",
		"postcss": "^8.5.9",
		"tailwindcss": "^4.2.2",
		"typescript": "^6.0.2",
		"vite": "^8.0.8"
